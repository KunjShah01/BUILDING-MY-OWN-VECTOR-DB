# =============================================================================
# Vector Database — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# ⚠️  WARNING: Never commit .env to version control! It contains secrets.
#    The .env.template file itself contains NO real secrets.
# =============================================================================



# =============================================================================
#  CRITICAL — Must Set Before Deployment
# =============================================================================

# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL="postgresql://vector_user:CHANGE_ME@postgres:5432/vector_db"

# API authentication key — used for all API requests sent via X-API-Key header
# Generate with: python -c "import secrets; print('vk_' + secrets.token_hex(24))"
API_KEY="vk_YOUR_RANDOM_API_KEY_HERE"

# Redis connection URL for caching, Celery broker, and rate limiting
REDIS_URL="redis://redis:6379/0"

# Encryption key for data-at-rest (32 hex bytes = 64 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=""


# =============================================================================
#  SECURITY — CORS, Hosts, OIDC
# =============================================================================

# Allowed CORS origins — comma-separated, no trailing slash.
# In production, list your exact domain(s), NEVER use "*".
# Example: "https://app.example.com,https://admin.example.com"
CORS_ORIGINS="https://your-domain.com"

# Allowed hosts — comma-separated list of domain names.
# In production, list your exact domain(s). "*" allows all hosts.
ALLOWED_HOSTS="your-domain.com,api.your-domain.com"

# ── OIDC / SSO Authentication (optional) ──────────────────────────────────────
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI="https://your-domain.com/auth/callback"


# =============================================================================
#  APPLICATION — General Settings
# =============================================================================

APP_NAME="Vector Database API"
APP_VERSION="1.0.0"

# Set to "true" only for local development (enables verbose logging, hot-reload)
DEBUG="false"

# Maximum HTTP request body size in MB (for file uploads and large payloads)
MAX_REQUEST_SIZE_MB="50"


# =============================================================================
#  RATE LIMITING — DDoS / Abuse Protection
# =============================================================================

# Enable or disable rate limiting entirely
RATE_LIMIT_ENABLED="true"

# Maximum requests per time window per client IP
RATE_LIMIT_REQUESTS="100"

# Time window in seconds for rate limit counting
RATE_LIMIT_TIME="60"

# Rate limit backend: "memory" (single-replica) or "redis" (production, multi-replica)
# IMPORTANT: Use "redis" when running 2+ API replicas to share counters
RATE_LIMIT_BACKEND="redis"


# =============================================================================
#  POSTGRESQL — Database (docker-compose only)
# =============================================================================

# Password for the PostgreSQL database user
# This is used in docker-compose.yaml — if you change it, update DATABASE_URL too
POSTGRES_PASSWORD="CHANGE_ME"


# =============================================================================
#  REDIS & CELERY — Background Task Processing
# =============================================================================

# Redis is used for: cache, Celery broker, Celery result backend, rate limiting
# Default URL points to the 'redis' service in docker-compose

# Celery broker URL (defaults to REDIS_URL if not set)
CELERY_BROKER_URL="redis://redis:6379/1"

# Celery result backend URL (defaults to REDIS_URL if not set)
CELERY_RESULT_BACKEND="redis://redis:6379/2"

# Set to "true" only when running tests without a Celery worker
CELERY_TASK_ALWAYS_EAGER="false"


# =============================================================================
#  INDEX TUNING — HNSW, IVF Parameters
# =============================================================================

# ── HNSW (Hierarchical Navigable Small World) ─────────────────────────────────
DEFAULT_M="32"                  # Max number of connections per element (higher = more recall, more memory)
DEFAULT_M0="64"                 # Max connections for layer 0 (typically 2× DEFAULT_M)
DEFAULT_EF_CONSTRUCTION="300"   # Build-time search width (higher = better quality, slower build)
DEFAULT_EF_SEARCH="50"          # Query-time search width (higher = better recall, slower queries)

# ── IVF (Inverted File Index) ─────────────────────────────────────────────────
DEFAULT_N_CLUSTERS="100"        # Number of clusters (higher = more accurate, more memory)
DEFAULT_N_PROBES="10"           # Number of clusters to probe at query time (higher = better recall)

# ── Distance Metric ──────────────────────────────────────────────────────────
# Supported: "cosine", "euclidean", "dot"
DEFAULT_DISTANCE_METRIC="cosine"


# =============================================================================
#  EMBEDDING — Model Configuration
# =============================================================================

# ── Text Embedding ────────────────────────────────────────────────────────────
DEFAULT_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
DEFAULT_TEXT_DIMENSION="384"

# ── Image Embedding (CLIP) ────────────────────────────────────────────────────
DEFAULT_IMAGE_MODEL="clip-ViT-B-32"
DEFAULT_IMAGE_DIMENSION="512"

# ── Audio Embedding (librosa MFCC) ────────────────────────────────────────────
DEFAULT_AUDIO_MODEL="librosa-mfcc-128"
DEFAULT_AUDIO_DIMENSION="128"
AUDIO_SAMPLE_RATE="22050"
AUDIO_MAX_DURATION_SEC="30.0"

# ── Hardware ──────────────────────────────────────────────────────────────────
# Device for running embedding models: "cpu" or "cuda" (for GPU)
EMBEDDING_DEVICE="cpu"


# =============================================================================
#  STORAGE — Media, Index, and Cloud Backends
# =============================================================================

# ── Local Storage Paths ───────────────────────────────────────────────────────
MEDIA_STORAGE_PATH="media_storage"

# ── Storage Provider ──────────────────────────────────────────────────────────
# Options: "local" (default), "s3" (AWS S3-compatible), "azure" (Azure Blob)
STORAGE_PROVIDER="local"

# ── S3 / AWS S3-Compatible Storage ───────────────────────────────────────────
S3_BUCKET="vector-db-storage"
S3_REGION="us-east-1"
# For MinIO or other S3-compatible services, set the endpoint URL:
S3_ENDPOINT_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER="vector-db-storage"

# ── Backup Storage (optional, separate from primary storage) ──────────────────
S3_BACKUP_BUCKET="vector-db-backups"
AZURE_BACKUP_CONTAINER="vector-db-backups"


# =============================================================================
#  LLM PROVIDERS — AI Model APIs (RAG, Chat, Streaming)
# =============================================================================
# At least one is needed for LLM-powered features. Free/open options marked ✓

# ── Free / Open Providers ─────────────────────────────────────────────────────

# Groq — free tier available, fast inference
GROQ_API_KEY=""

# Google Gemini / Google AI Studio — free tier available
GOOGLE_API_KEY=""

# OpenRouter — unified API for many models, free tier available
OPENROUTER_API_KEY=""

# Mistral AI — free tier available (mistral-small, mistral-medium)
MISTRAL_API_KEY=""

# NVIDIA NIM — free API credits available
NVIDIA_API_KEY=""

# Together AI — free tier available
TOGETHER_API_KEY=""

# DeepSeek — free tier available (deepseek-chat, deepseek-coder)
DEEPSEEK_API_KEY=""

# Hugging Face — free inference API (many community models)
HF_API_KEY=""

# ── Local LLM (no API key needed) ─────────────────────────────────────────────
# URL for Ollama running locally (e.g., http://host.docker.internal:11434)
OLLAMA_BASE_URL=""

# ── Paid Providers (optional) ─────────────────────────────────────────────────

# OpenAI — paid, most widely compatible (GPT-4, GPT-3.5, text-embedding-3-*)
OPENAI_API_KEY=""

# Anthropic — paid, best for long-context RAG (Claude 3/4)
ANTHROPIC_API_KEY=""


# =============================================================================
#  SEARCH PROVIDERS — Web Search, Internet Crawl
# =============================================================================
# At least one is needed for web search features. Free/self-hosted options marked ✓

# ── Self-Hosted (no API key) ──────────────────────────────────────────────────
# SearXNG — self-hosted meta search engine (runs in docker-compose)
SEARXNG_URL="http://searxng:8080"
SEARXNG_SECRET="generate-a-random-string-here"

# ── Free / Freemium Search APIs ───────────────────────────────────────────────

# Serper — Google Search API, 2500 free queries/month
SERPER_API_KEY=""

# Tavily — AI-native search, 1000 free queries/month
TAVILY_API_KEY=""

# Exa (formerly Metaphor) — neural search, 1000 free queries/month
EXA_API_KEY=""

# Brave Search — free for up to 2000 queries/month (rate-limited)
BRAVE_SEARCH_API_KEY=""

# SerpAPI — Google Search API, 100 free queries/month
SERPAPI_KEY=""


# =============================================================================
#  MULTI-REGION / CLUSTERING (optional, advanced)
# =============================================================================

# Comma-separated list of regions for multi-region replication
# Example: "us-east-1,eu-west-1,ap-southeast-1"
REGIONS=""

# PostgreSQL / pgvector compatibility toggle
USE_PGVECTOR="false"


# =============================================================================
#  WAL (Write-Ahead Log) Tuning
# =============================================================================

# Set to "1" to disable background WAL flusher (not recommended in production)
WAL_NO_BACKGROUND=""


# =============================================================================
#  MONITORING — Grafana & Observability
# =============================================================================

GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="CHANGE_ME_RANDOM_PASSWORD"


# =============================================================================
#  TLS / SSL — Certificate Paths (nginx)
# =============================================================================
# SSL certificates are configured in nginx.conf via file mounts, not env vars.
# Mount your certs at ./ssl/ in the project root.
# See: nginx.conf ssl_certificate / ssl_certificate_key directives.
